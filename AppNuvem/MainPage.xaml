<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppNuvem.MainPage">

    <StackLayout>
        <Frame BackgroundColor="#2196F3" Padding="24" CornerRadius="0">
            <Label Text="BD NUVEM" HorizontalTextAlignment="Center" TextColor="White" FontSize="36"/>
        </Frame>

        <StackLayout 
            Orientation="Horizontal" 
            HorizontalOptions="Center" 
            VerticalOptions="EndAndExpand" 
            Padding="10"
            Spacing="20"
            >
            <Button Text="+" 
                        BackgroundColor="#2196F3" 
                        FontAttributes="Bold" 
                        FontSize="40" 
                        x:Name="btnCadastrar" 
                        Clicked="btnCadastrar_Clicked" 
                        TextColor="White" 
                        HorizontalOptions="FillAndExpand"
                        VerticalOptions="FillAndExpand"
                        WidthRequest="80"
                            HeightRequest="80"
                            CornerRadius="40"
                        />

            <Button Text="SAIR" 
                    BackgroundColor="OrangeRed" 
                    FontAttributes="Bold" 
                    x:Name="btnSair" 
                    TextColor="White" 
                    Clicked="btnSair_Clicked"
                    WidthRequest="80"
                            HeightRequest="80"
                            CornerRadius="40"/>
                
            <Button Text="LISTAR" 
                    BackgroundColor="ForestGreen" 
                    FontAttributes="Bold" 
                    x:Name="btnListar" 
                    Clicked="btnListar_Clicked" 
                    TextColor="White" 
                    WidthRequest="80"
                            HeightRequest="80"
                            CornerRadius="40"/>
           
        </StackLayout>
        
        
    </StackLayout>

</ContentPage>
